{
  "manifest_version": 3,
  "name": "Email Hunter",
  "short_name": "Email Hunter",
  "description": "Extracts email addresses from pages as you browse. No tracking, no bandwidth sharing.",
  "version": "2.0",
  "icons": {
    "16": "img/16.png",
    "32": "img/32.png",
    "64": "img/64.png",
    "128": "img/128.png",
    "256": "img/256.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "img/16.png",
      "32": "img/32.png"
    }
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
